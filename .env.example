# ─────────────────────────────────────────────────────────────────────────
# 🔐 БЕЗОПАСНОСТЬ: НИКОГДА НЕ КОММИТЬТЕ РЕАЛЬНЫЕ КЛЮЧИ!
# ─────────────────────────────────────────────────────────────────────────

# ─── Anthropic ─────────────────────────────────────────────────────────────
# ТОЛЬКО для локальной разработки — в продакшене используйте Cloud Functions!
VITE_ANTHROPIC_KEY=sk-ant-...

# ─── Firebase ──────────────────────────────────────────────────────────────
# Эти ключи безопасны для фронтенда (используются только для клиентской auth)
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=jarvis-auto-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=jarvis-auto-prod
VITE_FIREBASE_STORAGE_BUCKET=jarvis-auto-prod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Cloud Functions URL ───────────────────────────────────────────────────
VITE_FUNCTIONS_URL=https://us-central1-jarvis-auto-prod.cloudfunctions.net

# ─── Feature flags ──────────────────────────────────────────────────────────
# true = прямой вызов Anthropic API (ТОЛЬКО для локальной разработки!)
# false = через Cloud Functions (продакшн — БЕЗ ПЕРЕДАЧИ КЛЮЧЕЙ)
VITE_DIRECT_API=false

# ─── Cloud Functions environment variables (для deploy) ─────────────────────
# В продакшене установите через Firebase CLI:
# firebase functions:config:set anthropic.api_key="sk-ant-..."
ANTHROPIC_API_KEY=sk-ant-...
ALLOWED_ORIGINS=https://jarvis-auto-psi.vercel.app,https://yourdomain.com
