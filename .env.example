# ─── Anthropic ───────────────────────────────────────────────────────────────
# ТОЛЬКО для локальной разработки — в продакшне используйте Cloud Functions!
VITE_ANTHROPIC_KEY=sk-ant-...

# ─── Firebase ────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=jarvis-auto-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=jarvis-auto-prod
VITE_FIREBASE_STORAGE_BUCKET=jarvis-auto-prod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Cloud Functions URL ──────────────────────────────────────────────────────
VITE_FUNCTIONS_URL=https://us-central1-jarvis-auto-prod.cloudfunctions.net

# ─── Feature flags ────────────────────────────────────────────────────────────
# true = прямой вызов Anthropic API (только dev!)
# false = через Cloud Functions (продакшн)
VITE_DIRECT_API=true
