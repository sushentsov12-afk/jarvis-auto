// public/manifest.json
{
  "name": "Jarvis Auto — ИИ-диагностика автомобиля",
  "short_name": "Jarvis Auto",
  "description": "Интеллектуальная платформа для диагностики, сервиса и учёта расходов автомобиля",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#060c18",
  "background_color": "#060c18",
  "categories": ["productivity", "automotive"],
  "lang": "ru-RU",
  
  "icons": [
    {
      "src": "/icons/favicon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/favicon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/favicon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/favicon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "screenshots": [
    {
      "src": "/screenshots/screenshot-1-540.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "/screenshots/screenshot-2-540.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "/screenshots/screenshot-1-1280.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide"
    }
  ],

  "shortcuts": [
    {
      "name": "Диагностика",
      "short_name": "Диагноз",
      "description": "Анализ кодов ошибок и симптомов",
      "url": "/?tab=diag",
      "icons": [
        {
          "src": "/icons/shortcut-diagnosis-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Сервисная книжка",
      "short_name": "Сервис",
      "description": "Управление ТО и обслуживанием",
      "url": "/?tab=maintain",
      "icons": [
        {
          "src": "/icons/shortcut-service-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Финансы",
      "short_name": "Расходы",
      "description": "Учет расходов и потребления топлива",
      "url": "/?tab=finance",
      "icons": [
        {
          "src": "/icons/shortcut-finance-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],

  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "image",
          "accept": ["image/jpeg", "image/png", "image/webp"]
        }
      ]
    }
  },

  "prefer_related_applications": false,
  "related_applications": []
}
