{
  "name": "jarvis-auto",
  "version": "9.0.0",
  "description": "AI-платформа управления автомобилем — Google Auth, диагностика OBD-II, Firestore sync",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "type-check": "tsc --noEmit",
    "analyze": "vite build --analyze",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "cd functions && npm run build && firebase deploy --only functions",
    "deploy:all": "npm run build && firebase deploy",
    "emulate": "firebase emulators:start"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "firebase": "^10.12.0",
    "zustand": "^4.5.5",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.24.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.7.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "terser": "^5.31.6"
  },
  "keywords": [
    "automotive",
    "obd2",
    "ai-diagnostics",
    "car",
    "react",
    "claude-ai",
    "firebase",
    "pwa"
  ],
  "author": "Jarvis Auto Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "> 0.2%",
    "not dead",
    "not op_mini all"
  ]
}
